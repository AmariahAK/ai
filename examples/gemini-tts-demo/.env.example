# gemini-tts-demo credentials — read as environment variables by server.mjs.
# Copy this file to `.env` and fill in the key(s) for the group(s) you want to
# test, then run `pnpm start`. Do NOT commit your real `.env`.

# Gemini API group (@ai-sdk/google): a Google AI Studio API key.
GOOGLE_GENERATIVE_AI_API_KEY=

# Vertex AI group (@ai-sdk/google-vertex), express mode: a Google Cloud / Vertex
# API key. NOTE: this is NOT an AI Gateway key.
# GOOGLE_VERTEX_API_KEY=

# Alternative to express mode: ADC. Leave GOOGLE_VERTEX_API_KEY blank, set these,
# and run `gcloud auth application-default login`.
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1

# Service-account auth (optional): set both to authenticate via credentials
# instead of ADC. GOOGLE_PRIVATE_KEY should be the PEM contents.
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
